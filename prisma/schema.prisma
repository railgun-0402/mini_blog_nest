generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organizations {
  id        String     @id @default(cuid())
  name      String
  users     Users[]
  companies Companies[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Users {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String
  organizationId String
  organization   Organizations @relation(fields: [organizationId], references: [id])
  notes          Notes[]
  refreshTokens  RefreshTokens[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model Companies {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organizations @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  websiteUrl     String?
  contacts       Contacts[]
  notes          Notes[]
  companyTags    CompanyTags[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@index([name])
}

model Contacts {
  id             String    @id @default(cuid())
  organizationId String
  companyId      String
  company        Companies @relation(fields: [companyId], references: [id])
  name           String
  email          String?
  position       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([companyId])
}

model Notes {
  id             String    @id @default(cuid())
  organizationId String
  companyId      String
  userId         String
  company        Companies @relation(fields: [companyId], references: [id])
  user           Users     @relation(fields: [userId], references: [id])
  body           String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([companyId])
  @@index([userId])
}

model Tags {
  id          String        @id @default(cuid())
  name        String        @unique
  companyTags CompanyTags[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model CompanyTags {
  companyId String
  tagId     String
  company   Companies @relation(fields: [companyId], references: [id])
  tag       Tags      @relation(fields: [tagId], references: [id])

  @@id([companyId, tagId])
}

model RefreshTokens {
  id        String   @id @default(cuid())
  userId    String
  user      Users    @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
